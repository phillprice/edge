#!/bin/sh
# Pre-commit: prettier + eslint + jest coverage on staged JS/JSX files.
# Enable once per clone:  git config core.hooksPath .githooks

staged=$(git diff --cached --name-only --diff-filter=ACMR -- '*.js' '*.jsx' '*.json' '*.css')
[ -z "$staged" ] && exit 0

root=$(git rev-parse --show-toplevel)
fail=0

backend_js=$(echo "$staged" | grep '^backend/.*\.js$' | sed 's|^backend/||')
frontend_js=$(echo "$staged" | grep '^frontend/src/.*\.\(js\|jsx\)$' | sed 's|^frontend/||')

# ── Prettier (backend) — auto-fix and re-stage ───────────────────────────────
if [ -n "$backend_js" ] && [ -x "$root/backend/node_modules/.bin/prettier" ]; then
  (cd "$root/backend" && echo "$backend_js" | xargs node_modules/.bin/prettier --write --log-level warn)
  echo "$staged" | grep '^backend/' | (cd "$root" && xargs git add)
fi

# ── Prettier (frontend) — check only ─────────────────────────────────────────
if [ -x "$root/frontend/node_modules/.bin/prettier" ]; then
  echo "$staged" | (cd "$root" && xargs frontend/node_modules/.bin/prettier --check --ignore-unknown) || fail=1
fi

# ── ESLint (backend) ─────────────────────────────────────────────────────────
if [ -n "$backend_js" ] && [ -x "$root/backend/node_modules/.bin/eslint" ]; then
  (cd "$root/backend" && echo "$backend_js" | xargs node_modules/.bin/eslint) || fail=1
fi

# ── ESLint (frontend) ────────────────────────────────────────────────────────
if [ -n "$frontend_js" ] && [ -x "$root/frontend/node_modules/.bin/eslint" ]; then
  (cd "$root/frontend" && echo "$frontend_js" | xargs node_modules/.bin/eslint) || fail=1
fi

# ── Jest coverage (backend) — runs when any backend JS is staged ─────────────
if [ -n "$backend_js" ] && [ -x "$root/backend/node_modules/.bin/jest" ]; then
  (cd "$root/backend" && node_modules/.bin/jest --coverage --passWithNoTests) || fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo ""
  echo "pre-commit failed — fix the errors above before committing."
  exit 1
fi
