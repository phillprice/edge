{
  "name": "cricket-frontend",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "format:check": "prettier --check --ignore-path ../.prettierignore --ignore-path .gitignore .",
    "format": "prettier --write --ignore-path ../.prettierignore --ignore-path .gitignore .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.9",
    "@sentry/react": "^10.65.0",
    "dompurify": "^3.4.12",
    "lucide-react": "^1.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "react-tooltip": "^6.0.8",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@clerk/backend": "^3.11.5",
    "@clerk/testing": "^2.2.8",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "3.9.5",
    "vite": "^8.1.4",
    "vitest": "^4.1.5"
  }
}
