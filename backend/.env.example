# Clerk authentication (https://clerk.com/docs)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ResultsVault / play-cricket API credentials
# Obtain from the ResultsVault API portal or your club admin contact.
RV_SHARED_SECRET=           # 3DES-ECB IAS token key
RV_ENTITY_ID=               # Club entity ID (numeric)
RV_API_ID=                  # API client ID (numeric)
RV_MAP_INSTANCE=4           # Instance ID for fixture mapping (usually 4)

# cron-job.org API key (for scheduling automatic ingests)
CRON_JOB_ORG_API_KEY=

# Telegram bot token — match summaries are sent to this bot after each ingest
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# The public URL of this server (used by cron-job.org webhooks to call back)
# e.g. https://edge-whcc.fly.dev for production, or an ngrok URL for local testing
APP_BASE_URL=http://localhost:3001

# Node environment
NODE_ENV=development
PORT=3001
