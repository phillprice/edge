# Clerk authentication (https://clerk.com/docs)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ResultsVault / play-cricket API credentials
# Obtain from the ResultsVault API portal or your club admin contact.
RV_SHARED_SECRET=           # 3DES-ECB IAS token key
RV_ENTITY_ID=               # Club entity ID (numeric)
RV_API_ID=                  # API client ID (numeric)
RV_MAP_INSTANCE=4           # Instance ID for fixture mapping (usually 4)

# cron-job.org API key (for scheduling automatic ingests)
CRON_JOB_ORG_API_KEY=

# Telegram bot token — used for per-user notifications and the /start onboarding flow.
# The bot replies to /start with the user's chat ID so they can paste it into
# their notification preferences.
TELEGRAM_BOT_TOKEN=
# Legacy global chat ID — optional; if set, match summaries are still sent here.
# New per-user notifications are routed to individual chat IDs from user_telegram table.
TELEGRAM_CHAT_ID=
# Random secret registered with Telegram's setWebhook to verify incoming webhook requests.
# Generate with: node -e "console.log(require('crypto').randomUUID())"
TELEGRAM_WEBHOOK_SECRET=

# Brevo transactional email (https://app.brevo.com → Settings → API Keys)
# BREVO_SENDER_EMAIL must be a verified sender in the Brevo dashboard.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=EDGE – WHCC Cricket

# The public URL of this server (used by cron-job.org + Telegram webhook + email unsubscribe links)
# e.g. https://edgexi.uk for production, or an ngrok URL for local testing
APP_BASE_URL=http://localhost:3001

# CORS — comma-separated allowed origins (defaults to localhost:5173)
CORS_ORIGINS=http://localhost:5173,https://edgexi.uk

# Node environment
NODE_ENV=development
PORT=3001
