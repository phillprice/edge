{
  "name": "cricket-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "format:check": "prettier --check --ignore-path ../.prettierignore --ignore-path .gitignore .",
    "format": "prettier --write --ignore-path ../.prettierignore --ignore-path .gitignore .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "seed:test": "node scripts/seed-test-db.js"
  },
  "jest": {
    "maxWorkers": 1,
    "globalTeardown": "./scripts/jest-teardown.js",
    "collectCoverageFrom": [
      "utils/**/*.js",
      "routes/**/*.js",
      "db/**/*.js",
      "middleware/**/*.js",
      "!**/*.test.js",
      "!**/node_modules/**",
      "!scripts/**"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 18,
        "functions": 12,
        "branches": 12,
        "statements": 18
      },
      "./utils/cricket.js": {
        "lines": 70,
        "functions": 70,
        "branches": 70,
        "statements": 70
      }
    }
  },
  "dependencies": {
    "@clerk/express": "^2.1.23",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "multer": "^2.0.1",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "10.5.0",
    "globals": "15.15.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "prettier": "3.8.4"
  }
}
