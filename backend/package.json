{
  "name": "cricket-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "seed:test": "node scripts/seed-test-db.js"
  },
  "jest": {
    "collectCoverageFrom": [
      "utils/cricket.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 70,
        "statements": 70
      }
    }
  },
  "dependencies": {
    "@clerk/express": "^2.1.14",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "multer": "^2.0.1",
    "node-cron": "^4.2.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.0"
  }
}
