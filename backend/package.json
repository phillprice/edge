{
  "name": "cricket-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "format:check": "prettier --check --ignore-path ../.prettierignore --ignore-path .gitignore .",
    "format": "prettier --write --ignore-path ../.prettierignore --ignore-path .gitignore .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "seed:test": "node scripts/seed-test-db.js"
  },
  "jest": {
    "maxWorkers": 1,
    "globalTeardown": "./scripts/jest-teardown.js",
    "collectCoverageFrom": [
      "utils/**/*.js",
      "routes/**/*.js",
      "services/**/*.js",
      "db/**/*.js",
      "middleware/**/*.js",
      "!**/*.test.js",
      "!**/node_modules/**",
      "!scripts/**"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 38,
        "functions": 39,
        "branches": 29,
        "statements": 37
      },
      "./utils/cricket.js": {
        "lines": 70,
        "functions": 70,
        "branches": 70,
        "statements": 70
      },
      "./utils/scorecard.js": {
        "lines": 24,
        "functions": 17,
        "branches": 23,
        "statements": 24
      },
      "./services/matchService.js": {
        "lines": 82,
        "functions": 64,
        "branches": 63,
        "statements": 79
      },
      "./services/matchEditService.js": {
        "lines": 95,
        "functions": 97,
        "branches": 84,
        "statements": 94
      },
      "./services/seasonStatsQueries.js": {
        "lines": 97,
        "functions": 97,
        "branches": 97,
        "statements": 97
      },
      "./services/topTrumpsService.js": {
        "lines": 97,
        "functions": 97,
        "branches": 97,
        "statements": 97
      },
      "./utils/resultsvault.js": {
        "lines": 19,
        "functions": 10,
        "branches": 15,
        "statements": 19
      },
      "./routes/admin/scheduler.js": {
        "lines": 86,
        "functions": 70,
        "branches": 69,
        "statements": 83
      }
    }
  },
  "dependencies": {
    "@clerk/express": "^2.1.44",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "marked": "18.0.7",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.4.3"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "prettier": "3.9.6",
    "supertest": "^7.2.2"
  }
}
